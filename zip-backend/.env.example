# Copy this file to .env and fill in your values
# NEVER commit .env to git

DEBUG=true
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:3001","http://localhost:3002","http://localhost:3003"]

# API Keys - get these from the links below
NEWSAPI_KEY=                    # https://newsapi.org
YOUTUBE_API_KEY=                # https://console.cloud.google.com
LISTENNOTES_API_KEY=            # https://listennotes.com/api
SPOTIFY_CLIENT_ID=              # https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_SECRET=          # https://developer.spotify.com/dashboard
SERPAPI_KEY=                    # https://serpapi.com
FACEBOOK_APP_ID=                # https://developers.facebook.com/apps
FACEBOOK_APP_SECRET=            # https://developers.facebook.com/apps

# Infrastructure
REDIS_URL=redis://localhost:6379

# Phase 2 - Onchain (leave blank for now)
PINATA_API_KEY=                 # https://pinata.cloud
PINATA_SECRET_KEY=              # https://pinata.cloud
